{
  "name": "sukyacc-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "cross-env NODE_ENV=development APP_URL=http://localhost:3000 electron .",
    "build": "tsc -p tsconfig.json",
    "start": "cross-env NODE_ENV=production electron .",
    "test:e2e": "node -e \"process.env.RUN_ELECTRON_E2E='1'; require('child_process').spawnSync('playwright',['test'],{stdio:'inherit',shell:true,env:process.env});\"",
    "dist:dir": "npm run build && electron-builder --dir",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@types/node": "^20.19.1",
    "cross-env": "^7.0.3",
    "electron": "^35.1.4",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.sukyacc.app",
    "productName": "SukyAcc",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://example.com/updates/"
      }
    ]
  }
}
